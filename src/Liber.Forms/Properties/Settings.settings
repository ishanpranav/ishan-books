    "strict": true
  },
  {
    "filter": "(Retained Earning|Accumulated Deficit)",
    "type": "equity",
    "equity": true,
    "strict": true
  },
  {
    "filter": "(Individual|ESPP) Short[-\\s]Term",
    "cashFlow": "investing",
    "strict": true
  },
  {
    "filter": "Chase Bank",
    "color": -16752968
  },
  {
    "filter": "Venmo",
