  },
  {
    "filter": "^2[5-9]",
    "type": "longTermLiability"
  },
  {
    "filter": "Accumulated Other Comprehensive",
    "cashFlow": "otherEquity",
    "otherEquity": true,
    "strict": true
  },
  {
