    <Setting Name="ImportRules" Type="System.String" Scope="User">
      <Value Profile="(Default)">[
  {
    "filter": "^7",
    "type": "incomeTaxExpense",
    "strict": true
  },
  {
    "filter": "^6",
    "type": "otherIncomeExpense",
    "strict": true
  },
  {
