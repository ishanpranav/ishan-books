<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title></title>
    <link rel="stylesheet" href="../styles/chart.css" type="text/css" />
</head>
<body>
    <div class="chart-container">
        <canvas id="chart"></canvas>
    </div>
    <script type="text/javascript" src="https://liber.example/scripts/chart.js"></script>
    <script type="text/javascript" src="https://liber.example/scripts/chartjs-chart-treemap.js"></script>
    <script type="text/javascript">
        window.report = {
            getReport: (report) => report.getAccountMap
        };
    </script>
    <script type="text/javascript" src="https://liber.example/scripts/account-map.js"></script>
</body>
</html>
